{
  "name": "fitia-pro-miner",
  "version": "3.0.0",
  "description": "FITIA PRO MINER — DApp de minage FTA sur Polygon. Connexion Web3Auth (Email/Google) + préparation export APK Capacitor.",
  "private": true,
  "author": "FITIA",
  "license": "MIT",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 --cors",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "build:android": "npm run cap:sync && npm run cap:open:android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "http-server": "^14.1.1"
  },
  "capacitor": {
    "configFile": "capacitor.config.json"
  }
}
